{
  "$meta": {
    "name": "LivePlace Design Tokens — Arcade (direction retenue, FEN-196)",
    "version": "0.2.0",
    "theme": "light",
    "source": "maquettes/src/styles/tokens.css",
    "note": "Primitives + neutral UI + semantic status are direction-agnostic. The `direction.arcade` block is the retained brand layer (data-direction=\"fun\")."
  },
  "primitive": {
    "gray": { "0": "#ffffff", "25": "#f7f7f8", "50": "#f0f0f2", "100": "#e7e7ea", "150": "#dcdce0", "200": "#cfcfd4", "300": "#b7b7be", "400": "#90909a", "500": "#6c6c76", "600": "#52525b", "700": "#3d3d45", "800": "#292930", "900": "#18181c" },
    "status": { "green-500": "#198547", "green-100": "#dcf3e4", "amber-500": "#b06f00", "amber-100": "#fbeccb", "red-500": "#c2371d", "red-100": "#fbe3dd", "blue-500": "#2563c9", "blue-100": "#dde9fb" },
    "space": { "0": "0px", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px" },
    "text": { "xs": ["12px","16px"], "sm": ["14px","20px"], "base": ["16px","24px"], "lg": ["18px","26px"], "xl": ["22px","28px"], "2xl": ["28px","34px"], "3xl": ["36px","42px"] },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "radius": { "xs": "4px", "sm": "6px", "md": "10px", "lg": "14px", "xl": "20px", "pill": "999px" },
    "elev": {
      "1": "0 1px 2px rgba(24,24,28,.06), 0 1px 1px rgba(24,24,28,.04)",
      "2": "0 2px 6px rgba(24,24,28,.08), 0 1px 2px rgba(24,24,28,.06)",
      "3": "0 8px 24px rgba(24,24,28,.12), 0 2px 6px rgba(24,24,28,.08)",
      "obs": "0 0 0 2px rgba(0,0,0,.55), 0 2px 8px rgba(0,0,0,.45)"
    },
    "motion": {
      "dur": { "instant": "90ms", "fast": "150ms", "base": "220ms", "slow": "320ms" },
      "ease": { "out": "cubic-bezier(.22,.78,.27,1)", "in-out": "cubic-bezier(.5,0,.2,1)", "spring": "cubic-bezier(.2,1.3,.4,1)" }
    }
  },
  "ui": {
    "bg": "{gray.100}", "surface": "{gray.25}", "surface-raised": "{gray.0}",
    "border": "{gray.150}", "border-strong": "{gray.300}",
    "text": "{gray.900}", "text-secondary": "{gray.600}", "text-tertiary": "{gray.500}", "text-onAccent": "{gray.0}",
    "canvas-field": "#cfcfd4", "canvas-checker": "#c6c6cc", "canvas-grid": "rgba(24,24,28,.10)", "canvas-frame": "{gray.300}"
  },
  "status": {
    "open": { "fg": "{status.green-500}", "bg": "{status.green-100}" },
    "cooldown": { "fg": "{status.amber-500}", "bg": "{status.amber-100}" },
    "frozen": { "fg": "{status.blue-500}", "bg": "{status.blue-100}" },
    "ended": { "fg": "{gray.600}", "bg": "{gray.100}" },
    "error": { "fg": "{status.red-500}", "bg": "{status.red-100}" }
  },
  "direction": {
    "arcade": {
      "data-direction": "fun",
      "font-display": "\"Press Start 2P\", \"Inter\", system-ui, sans-serif",
      "font-display-usage": "wordmark + celebration headline ONLY (perf + legibility) — never body",
      "accent": "#d6381f",
      "accent-hover": "#c0331b",
      "accent-active": "#a82d18",
      "accent-text": "#bd3221",
      "accent-show": "#ef4d3a",
      "accent-soft": "#fde3df",
      "accent-ring": "#d6381f",
      "accent-2": "#f4a020",
      "accent-onAccent": "#ffffff",
      "accent-notes": "accent = AA white-text on buttons (4.7:1). accent-text = coral on light surfaces (AA 4.5:1+). accent-show #ef4d3a = bright coral for DECORATIVE-only moments (marks, confetti) — never as text.",
      "radius-control": "{radius.xs}",
      "radius-card": "{radius.sm}",
      "elev-control": "{elev.2}",
      "motion-scale": 1.15
    }
  },
  "brand-locked": {
    "twitch-purple": "#9146FF"
  }
}
