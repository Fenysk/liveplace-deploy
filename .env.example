# ─────────────────────────────────────────────────────────────────────────────
# Twitch Canvas — environment template.
# Copy to `.env` and fill in. NEVER commit `.env` (it is gitignored).
# Secrets on the NAS should be provided via Docker secrets / env, not the repo.
# ─────────────────────────────────────────────────────────────────────────────

# --- Public URLs (reverse proxy / TLS owned by DevOps, see D5) ---
# Public origin the browser hits. Must be HTTPS for the Twitch OAuth callback.
PUBLIC_SITE_URL=https://canvas.example.com
# Public WebSocket origin (gateway), e.g. wss://canvas.example.com/ws
PUBLIC_WS_URL=wss://canvas.example.com/ws
# Caddy site address — decides scheme/port (infra/Caddyfile, FEN-78 #4):
#   :80                  -> HTTP-only on port 80, all hosts (local / behind a
#                           proxy or tunnel). This is the default; leave it for a
#                           local smoke.
#   canvas.example.com   -> bare public host: Caddy auto-provisions HTTPS (TLS).
#   https://nas.local    -> LAN HTTPS (also uncomment `tls internal` in Caddyfile).
SITE_ADDRESS=:80
# Host ports the reverse proxy publishes (FEN-78 #5). Change these if 80/443 are
# already taken on the host (system Caddy, Supabase Kong on 8443, etc.). The
# container always listens on 80/443 internally.
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# --- Twitch OAuth (Better Auth social provider) ---
# Create an app at https://dev.twitch.tv/console/apps
# OAuth Redirect URL must be: ${PUBLIC_SITE_URL}/api/auth/callback/twitch
TWITCH_CLIENT_ID=replace-me
TWITCH_CLIENT_SECRET=replace-me

# --- Better Auth ---
# 32+ char random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
BETTER_AUTH_URL=https://canvas.example.com

# --- Convex (self-hosted) ---
# For self-hosted Convex backend. See https://docs.convex.dev/self-hosting
CONVEX_SELF_HOSTED_URL=http://convex-backend:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-me
# Instance secret for the self-hosted backend (`openssl rand -hex 32`)
CONVEX_INSTANCE_SECRET=replace-me
# Public deployment URL the web client uses to reach Convex (cloud origin, :3210)
VITE_CONVEX_URL=https://canvas.example.com/convex
# Public Convex SITE origin (HTTP actions, :3211) — Better Auth + the Twitch
# OAuth callback live here; the SPA's auth client uses it. Proxied at /api/auth*.
VITE_CONVEX_SITE_URL=https://canvas.example.com

# --- Redis (hot path) ---
REDIS_URL=redis://redis:6379

# --- Gateway (WS) ---
GATEWAY_PORT=8080
# Canvas dimensions — provisional contract (see protocol package). Tunable until D1.
CANVAS_WIDTH=512
CANVAS_HEIGHT=512

# Canvas identity (ADR-0001): the WS canvas id == the per-canvas Redis key
# namespace == the F2 canvas `slug`. The gateway, place.lua, and the persistence
# worker MUST all use this same value. Single-canvas MVP.
GATEWAY_CANVAS_ID=default

# --- Moderation internal seam (F8: gateway FEN-19 <-> Convex FEN-52) ---
# Contract: docs/contracts/moderation-internal.md.
# Shared bearer secret guarding the gateway's POST /internal/{moderate,ban,freeze,
# flush} routes. The gateway reads it (apps/gateway/src/config.ts -> internalSecret)
# from its container env; Convex sends it as `Authorization: Bearer <secret>`.
#   - UNSET on the gateway  => the whole seam is DISABLED (routes answer 404).
#   - present but wrong/absent Bearer => 401.
#   - UNSET on Convex       => actions still record durable state but report
#                              `gateway_not_configured` (no throw).
# The SAME value must be set for the gateway and Convex. Generate: `openssl rand -hex 32`.
GATEWAY_INTERNAL_SECRET=replace-me-with-a-long-random-string
# Base URL Convex uses to reach the gateway's internal API over the compose
# network (service name `gateway`, GATEWAY_PORT). Internal only — never exposed
# publicly by the proxy.
GATEWAY_INTERNAL_URL=http://gateway:8080

# --- Persistence worker (durable layer, off the hot path: FEN-47 / FEN-57) ---
# Reuses REDIS_URL, CONVEX_SELF_HOSTED_URL, GATEWAY_CANVAS_ID, CANVAS_WIDTH/HEIGHT above.
FLUSH_INTERVAL_MS=2000
FLUSH_MAX_BATCH=500
SNAPSHOT_INTERVAL_MS=60000
SNAPSHOT_EVERY_N_VERSIONS=5000
# F12 gallery activation (FEN-33): viewer-count flush cadence + thumbnail cap (0 disables).
VIEWER_FLUSH_INTERVAL_MS=10000
THUMBNAIL_MAX_LONG_SIDE=256
