# Twitch Canvas reverse proxy (D4/D5, owned by DevOps).
#
# The site ADDRESS is driven by $SITE_ADDRESS and decides the scheme/port:
#   - default `:80`   -> HTTP-only on port 80, accepts ALL hostnames. This is the
#                        reliable local / behind-a-proxy / behind-a-tunnel mode.
#                        A bare host like `localhost` is NOT enough: Caddy would
#                        bind 443 and redirect :80 -> :443, so plain HTTP fails
#                        (FEN-78 #4). `:80` forces a real HTTP listener.
#   - `canvas.example.com` (a bare public host) -> Caddy auto-provisions TLS
#                        (Let's Encrypt) and serves HTTPS on 443.
#   - `https://nas.local` + `tls internal` below -> LAN HTTPS with a self-signed CA.
# Set it in .env: SITE_ADDRESS. The host port the proxy binds is separate and is
# configured by PROXY_HTTP_PORT / PROXY_HTTPS_PORT in docker-compose.yml.
#
# Routing model (canonical _default — web is a pure SPA, auth lives in Convex):
#   /ws*        -> gateway   (WebSocket, ADR-0003)
#   /api/auth*  -> convex SITE origin (:3211)  — Better Auth + the Twitch OAuth
#                  callback (${PUBLIC_SITE_URL}/api/auth/callback/twitch). This
#                  is the D5 deliverable: the callback reachable over HTTPS.
#   /convex*    -> convex CLOUD origin (:3210) — the Convex client API/sync.
#   everything  -> web       (static SPA assets)
#
# The convex backend serves both origins at their own roots, so we strip the
# public path prefixes with `handle_path` before proxying upstream.
{$SITE_ADDRESS::80} {
	# tls internal   # uncomment for a LAN-only NAS over HTTPS (self-signed CA)

	encode gzip zstd

	# Security headers (FEN-87, defence-in-depth — no player-facing behaviour).
	#
	# Same-origin model: the SPA, Convex client API/sync (/convex), Better Auth
	# (/api/auth) and the WS gateway (/ws) are ALL served from THIS origin, so
	# `'self'` already covers https fetch + same-host wss — no separate Convex /
	# gateway origins need listing in the default deployment. For a SPLIT-origin
	# Convex (Convex on its own host), append space-separated origins via env:
	#   CSP_CONNECT_EXTRA="https://convex.example.com wss://convex.example.com"
	#   CSP_IMG_EXTRA="https://convex.example.com"
	#
	# script-src stays strict 'self' (the built SPA loads only external module
	# scripts — verified, no inline). style-src allows 'unsafe-inline' because the
	# bundler/UI may inject <style>; inline style is low-risk vs inline script.
	# img-src adds the Twitch avatar CDN (profile/gallery avatars) + data: URIs.
	header {
		Content-Security-Policy "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://static-cdn.jtvnw.net {$CSP_IMG_EXTRA:}; font-src 'self' data:; connect-src 'self' {$CSP_CONNECT_EXTRA:}"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# WebSocket gateway (separate service, ADR-0003).
	@ws path /ws /ws/*
	reverse_proxy @ws gateway:8080

	# Better Auth HTTP routes incl. the Twitch OAuth callback (Convex site origin).
	# Kept at the site root (/api/auth*) — Better Auth registers its routes there,
	# so no prefix is stripped.
	handle /api/auth* {
		reverse_proxy convex-backend:3211
	}

	# Convex client API/sync. VITE_CONVEX_URL = https://<host>/convex; strip the
	# /convex prefix so the backend (which serves at root) sees the bare path.
	handle_path /convex/* {
		reverse_proxy convex-backend:3210
	}

	# Static SPA (canvas, gallery, profile, OBS view, …).
	reverse_proxy web:3000
}
