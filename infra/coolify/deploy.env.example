# ─────────────────────────────────────────────────────────────────────────────
# LivePlace — Coolify agent-only deploy inputs (FEN-80, exec of FEN-79).
#
# Copy to `infra/coolify/deploy.env` (gitignored) and fill in. `scripts/
# coolify-wire-source.mjs` sources this for ONE-TIME provisioning: wire the
# Coolify app to the mirror source + write back COOLIFY_GIT_REPOSITORY. After
# that, every deploy goes through the ONE guarded path — `scripts/mirror-push.mjs`
# → Coolify force-deploy API → poll → verify served surface (see
# docs/runbooks/coolify-deploy.md). There is NO end-to-end deploy script anymore
# (coolify-deploy.mjs was removed, FEN-2056/D1 — it had clobbered prod, FEN-1625).
#
# NOTHING here is committed with real values. Secrets are provided once at
# provisioning time (board/Alexis via the CEO) exactly like the Twitch creds.
# ─────────────────────────────────────────────────────────────────────────────

# ── Coolify connection (Phase-B inputs from Alexis via CEO) ──────────────────
# Base URL of the Coolify instance, no trailing slash.
# KNOWN (FEN-80): https://coolify.fenysk.fr — baked as the script default, leave blank.
COOLIFY_URL=
# API token with deploy + write + read scopes (Bearer).
# NOTE: Alexis regenerated the token into the env var COOLIFY_API_TOKEN_2 (the
# original COOLIFY_API_TOKEN is stale). The script reads COOLIFY_API_TOKEN_2 from
# the real environment automatically — only set this if you paste a token here.
COOLIFY_API_TOKEN=

# ── Coolify placement (read once from the Coolify UI / API, then fixed) ──────
# Target project + server + environment the app is created in.
# KNOWN (FEN-80): project = LivePlace, uuid tgxjp2pout8sab9fp5edtbhb (baked as the
# script default + HARD GUARDRAIL — it refuses to touch any other project). The
# server uuid auto-resolves from the API if there is exactly one server; set it
# only to disambiguate. Environment = production.
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_ENVIRONMENT_NAME=production
# Display name for the application in Coolify.
COOLIFY_APP_NAME=liveplace
# Set AFTER the first create to make every later run idempotent (skip create,
# just push env + redeploy). The deploy script prints this on first success.
COOLIFY_APP_UUID=

# ── Source Coolify pulls (Phase-A decision: public git repo + compose buildpack) ──
# A git URL Coolify can clone. Our compose BUILDS images from in-repo Dockerfiles,
# so Coolify needs the full source tree — a raw-compose upload cannot build it.
# A PUBLIC repo needs no deploy key; that is the simplest durable option.
# Seed it from the bundle produced by `node scripts/make-deploy-bundle.mjs`.
COOLIFY_GIT_REPOSITORY=
COOLIFY_GIT_BRANCH=main
# Path of the compose file inside the repo (build pack = dockercompose).
COOLIFY_COMPOSE_LOCATION=/docker-compose.yml

# ── Public URL Coolify serves (TLS terminated at the Coolify edge) ───────────
# The FQDN routed to the `proxy` service. If left blank the script asks Coolify
# to autogenerate a domain and reads it back. Everything else (VITE_*, auth URL)
# is derived from this. Internally the stack stays HTTP (SITE_ADDRESS=:80) because
# Coolify's proxy does TLS — D5 (HTTPS Twitch callback) is satisfied at the edge.
PUBLIC_BASE_URL=

# ── Stack secrets (the convex-deploy gate + auth need these) ─────────────────
# Random secrets the deploy script GENERATES for you if left blank (and prints a
# reminder to persist them in Coolify so redeploys stay stable):
BETTER_AUTH_SECRET=
GATEWAY_INTERNAL_SECRET=
CONVEX_INSTANCE_SECRET=
# The self-hosted Convex admin key is DETERMINISTIC per CONVEX_INSTANCE_SECRET and
# is now minted IN-STACK at `up` time by the `convex-admin-key` one-shot in
# docker-compose.yml (FEN-92) — it runs the same `generate_admin_key.sh` from the
# convex-backend image and hands the key to convex-deploy via a shared volume.
# LEAVE THIS BLANK: no on-box `generate_admin_key.sh` / Coolify-terminal step.
# Set a value only to pin an externally-minted key (must match CONVEX_INSTANCE_SECRET).
CONVEX_SELF_HOSTED_ADMIN_KEY=

# ── Canvas identity (REQUIRED for persistence — FEN-698) ─────────────────────
# The WS canvas id == Redis key namespace == Convex canvas slug. Must be the
# Twitch login of the canvas owner (e.g. "fenysk" for https://liveplace.tv/fenysk).
# "default" is a RESERVED slug (canvases.ts) — no Convex canvas row can ever
# have it. If left at "default", the worker calls applyFlush("default") →
# canvasFound:false → totalPixels=0, lastActivityAt frozen forever (FEN-698).
GATEWAY_CANVAS_ID=

# ── Mode ─────────────────────────────────────────────────────────────────────
# 0 = Twitch OAuth (the SAFE default — what prod runs). 1 = anonymous stack (no
# Twitch, every socket accepted, canvas globally writable) — a throwaway smoke
# mode only. Pass to 1 UNIQUEMENT pour un smoke anonyme jetable.
#
# FEN-1018/AP-10: fail-closed. Prod (liveplace.tv) MUST stay 0; this value is set
# once in the Coolify app-env and never flipped for a normal deploy. Only a
# throwaway anon smoke stack ever sets "1", and only in a disposable Coolify app —
# never the served prod app — so an accidental "1" can never silently open the canvas.
#
# FEN-1008/FEN-1009/FEN-978: the liveplace.tv PROD deploy MUST be 0. Coolify injects
# every app-env var into every compose service, so a stray "1" here reaches the
# gateway and the auth-disabled branch (auth.ts) returns userId="anon" for EVERY
# socket — even fully signed-in Twitch users — making all pixels "Posé anonymement".
# With 0 the gateway verifies the Convex JWT offline against CONVEX_JWKS_URL (already
# pinned internal on the gateway service in docker-compose.yml) and attributes the
# real login.
GATEWAY_AUTH_DISABLED=0
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
