# ─────────────────────────────────────────────────────────────────────────────
# LivePlace — Coolify agent-only deploy inputs (FEN-80, exec of FEN-79).
#
# Copy to `infra/coolify/deploy.env` (gitignored) and fill in. `scripts/
# coolify-deploy.mjs` sources this, then drives the Coolify API end to end:
#   create/reuse a Docker-Compose app from a git source → push the stack env →
#   instant_deploy → wait healthy → run scripts/smoke.mjs against the Coolify URL.
#
# NOTHING here is committed with real values. Secrets are provided once at
# provisioning time (board/Alexis via the CEO) exactly like the Twitch creds.
# After the first run, every future update is a single API call (re-run with
# COOLIFY_APP_UUID set, or just `GET /api/v1/deploy?uuid=…` on a git push).
# ─────────────────────────────────────────────────────────────────────────────

# ── Coolify connection (Phase-B inputs from Alexis via CEO) ──────────────────
# Base URL of the Coolify instance, no trailing slash, e.g. https://coolify.alexis.dev
COOLIFY_URL=
# API token with deploy + write + read scopes (Bearer).
COOLIFY_API_TOKEN=

# ── Coolify placement (read once from the Coolify UI / API, then fixed) ──────
# Target project + server + environment the app is created in.
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_ENVIRONMENT_NAME=production
# Display name for the application in Coolify.
COOLIFY_APP_NAME=liveplace
# Set AFTER the first create to make every later run idempotent (skip create,
# just push env + redeploy). The deploy script prints this on first success.
COOLIFY_APP_UUID=

# ── Source Coolify pulls (Phase-A decision: public git repo + compose buildpack) ──
# A git URL Coolify can clone. Our compose BUILDS images from in-repo Dockerfiles,
# so Coolify needs the full source tree — a raw-compose upload cannot build it.
# A PUBLIC repo needs no deploy key; that is the simplest durable option.
# Seed it from the bundle produced by `node scripts/make-deploy-bundle.mjs`.
COOLIFY_GIT_REPOSITORY=
COOLIFY_GIT_BRANCH=main
# Path of the compose file inside the repo (build pack = dockercompose).
COOLIFY_COMPOSE_LOCATION=/docker-compose.yml

# ── Public URL Coolify serves (TLS terminated at the Coolify edge) ───────────
# The FQDN routed to the `proxy` service. If left blank the script asks Coolify
# to autogenerate a domain and reads it back. Everything else (VITE_*, auth URL)
# is derived from this. Internally the stack stays HTTP (SITE_ADDRESS=:80) because
# Coolify's proxy does TLS — D5 (HTTPS Twitch callback) is satisfied at the edge.
PUBLIC_BASE_URL=

# ── Stack secrets (the convex-deploy gate + auth need these) ─────────────────
# Random secrets the deploy script GENERATES for you if left blank (and prints a
# reminder to persist them in Coolify so redeploys stay stable):
BETTER_AUTH_SECRET=
GATEWAY_INTERNAL_SECRET=
CONVEX_INSTANCE_SECRET=
# The self-hosted Convex admin key is DETERMINISTIC per CONVEX_INSTANCE_SECRET but
# is minted by the backend binary (`generate_admin_key.sh`), so it cannot be
# precomputed off-box. First run only: bring the backend up, then
#   <coolify> exec <convex-backend container> ./generate_admin_key.sh
# (or the Coolify UI terminal), paste the value here, and re-run. It never
# changes for a given instance secret, so this is a one-time provisioning step —
# not a per-deploy intervention. The script guides you if it is missing.
CONVEX_SELF_HOSTED_ADMIN_KEY=

# ── Mode ─────────────────────────────────────────────────────────────────────
# 1 = anonymous stack (no Twitch, every socket accepted) — the Phase-B first
# smoke target. Set to 0 and provide TWITCH_CLIENT_ID/SECRET for the real OAuth
# stack once the anon smoke is green.
GATEWAY_AUTH_DISABLED=1
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
