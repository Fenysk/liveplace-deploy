    "lint": "pnpm -r --if-present lint"
  },
  "devDependencies": {
    "@types/node": "22",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17"
    }
  }
}
