{
  "name": "twitch-canvas",
  "version": "0.0.1",
  "private": true,
  "description": "Twitch-integrated real-time collaborative pixel canvas (r/place-style).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
