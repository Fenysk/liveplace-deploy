  },
  "dependencies": {
    "@canvas/canvas-rules": "workspace:*",
    "@canvas/points-rules": "workspace:*",
    "@convex-dev/better-auth": "0.12.2",
    "better-auth": "1.6.13",
    "convex": "^1.39.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
