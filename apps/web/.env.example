# ─────────────────────────────────────────────────────────────────────────────
# @canvas/web — front-end env template (Vite).
#
# Why this file exists (FEN-322): `pnpm --filter @canvas/web dev` boots a BLANK
# PAGE when `VITE_CONVEX_URL` is missing — `ConvexReactClient(undefined)` throws
# at module load. Vite reads `.env` from THIS directory (the app root), NOT the
# monorepo root, so the repo-root `.env.example` does not cover the web app.
#
# QA / local: copy to `.env` here  ->  `cp apps/web/.env.example apps/web/.env`
# then fill the values below. `.env` is gitignored — never commit it.
# (Only `VITE_*` vars are exposed to the browser bundle; nothing else leaks.)
# ─────────────────────────────────────────────────────────────────────────────

# --- REQUIRED ---------------------------------------------------------------
# Convex deployment URL the SPA connects to (cloud origin, :3210).
# Get it from a running `pnpm --filter @canvas/convex dev` (it prints the URL),
# or use the shared QA/staging deployment URL.
VITE_CONVEX_URL=http://127.0.0.1:3210

# --- REQUIRED for auth (Twitch sign-in / placing pixels) --------------------
# Convex SITE origin (HTTP actions, :3211). Better Auth + the Twitch OAuth
# callback live here; the SPA auth client uses it as its baseURL.
# Anonymous canvas viewing works without it, but sign-in / pose flows need it.
VITE_CONVEX_SITE_URL=http://127.0.0.1:3211

# --- OPTIONAL ---------------------------------------------------------------
# Gateway WebSocket override. Leave UNSET to derive `ws(s)://<page-host>/canvas/
# {slug}/ws` from the page origin (the normal Compose/NAS topology). Set it only
# for split dev where the gateway runs on a different host/port.
# VITE_WS_URL=ws://127.0.0.1:8080
